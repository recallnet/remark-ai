{
  "name": "remark-docs-governance",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/check-exports.mjs",
    "test": "node --test packages/*/test/*.test.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "cpd": "jscpd packages/ scripts/ --config .jscpd.json",
    "cpd:tests": "jscpd packages/ --config .jscpd.tests.json",
    "knip": "knip --include files",
    "check": "pnpm format:check && pnpm lint && pnpm test && pnpm build",
    "prepare": "husky",
    "docs:lint": "recall-docs-governance lint",
    "docs:lint:changed": "recall-docs-governance lint --changed"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^22.18.6",
    "@eslint/js": "^9.39.1",
    "@recallnet/docs-governance-preset": "workspace:*",
    "@recallnet/codecontext-cli": "^0.2.0",
    "@recallnet/codecontext-eslint-plugin": "^0.3.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^61.0.2",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.7",
    "knip": "^5.66.1",
    "lint-staged": "^16.2.0",
    "prettier": "^3.6.2",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
